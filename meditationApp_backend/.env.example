# ─── Base de datos ──────────────────────────────────────
# Usar DATABASE_URL para producción (Render, Railway, etc.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# O bien variables individuales para desarrollo local:
# DB_USER=miusuario
# DB_HOST=localhost
# DB_DATABASE=meditation_db
# DB_PASSWORD=miclave
# DB_PORT=5432

# ─── JWT ────────────────────────────────────────────────
# Mínimo 32 caracteres, generado aleatoriamente
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio_minimo_32_chars

# ─── Servidor ───────────────────────────────────────────
PORT=3000

# ─── CORS ───────────────────────────────────────────────
# URL del frontend (sin barra al final)
FRONTEND_URL=http://localhost:5173
